<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="FluentIcons.Gallery.TutorialPage">

    <ScrollViewer>
        <StackPanel Margin="40,10,40,32" Spacing="24">

            <!-- Getting Started -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="Rocket" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="GettingStartedTitle" Text="Getting Started" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="GettingStartedDesc" TextWrapping="Wrap" Opacity="0.8" FontSize="14" LineHeight="22"/>
                </StackPanel>
            </Border>

            <!-- Step 1: Install -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="ArrowDownload" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="InstallTitle" Text="Step 1: Install NuGet Package" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="InstallDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                   Foreground="#D4D4D4" TextWrapping="Wrap">
&lt;PackageReference Include="FluentIcons.Avalonia" Version="2.1.329" /&gt;
                        </TextBlock>
                    </Border>
                    <TextBlock x:Name="InstallCmd" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                   Foreground="#D4D4D4">
dotnet add package FluentIcons.Avalonia
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Step 2: XAML Usage -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="Code" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="XamlUsageTitle" Text="Step 2: Use Icons in XAML" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="XamlUsageDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                   Foreground="#CE9178" TextWrapping="Wrap">
xmlns:ic="using:FluentIcons.Avalonia"
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Basic Usage -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="Star" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="XamlBasicTitle" Text="Basic Usage" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="XamlBasicDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <StackPanel Spacing="4">
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#CE9178" TextWrapping="Wrap">
&lt;ic:FluentIcon Icon="Home" FontSize="24" /&gt;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#CE9178" TextWrapping="Wrap">
&lt;ic:FluentIcon Icon="Settings" FontSize="32" /&gt;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#CE9178" TextWrapping="Wrap">
&lt;ic:FluentIcon Icon="Heart" FontSize="16" /&gt;
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Home" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Home 24px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Settings" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Settings 32px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Heart" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Heart 16px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Icon Variants -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="DesignIdeas" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="VariantsTitle" Text="Icon Style Variants" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="VariantsDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>

                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <StackPanel Spacing="4">
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#6A9955">
&lt;!-- Regular (default) --&gt;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#CE9178" TextWrapping="Wrap">
&lt;ic:FluentIcon Icon="Home" FontSize="32" /&gt;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#6A9955">
&lt;!-- Filled --&gt;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#CE9178" TextWrapping="Wrap">
&lt;ic:FluentIcon Icon="Home" FontSize="32" IconVariant="Filled" /&gt;
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="32" Margin="0,8,0,0">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Home" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Regular" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Home" FontSize="32" IconVariant="Filled" HorizontalAlignment="Center"/>
                            <TextBlock Text="Filled" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Star" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Regular" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <ic:FluentIcon Icon="Star" FontSize="32" IconVariant="Filled" HorizontalAlignment="Center"/>
                            <TextBlock Text="Filled" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6" Margin="0,8,0,0">
                        <TextBlock x:Name="VariantRegular" TextWrapping="Wrap" Opacity="0.75" FontSize="13"/>
                        <TextBlock x:Name="VariantFilled" TextWrapping="Wrap" Opacity="0.75" FontSize="13"/>
                        <TextBlock x:Name="VariantColor" TextWrapping="Wrap" Opacity="0.75" FontSize="13"/>
                        <TextBlock x:Name="VariantLight" TextWrapping="Wrap" Opacity="0.75" FontSize="13"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sizing -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="ResizeLarge" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="SizingTitle" Text="Adjusting Icon Size" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="SizingDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <StackPanel Spacing="4">
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#CE9178" TextWrapping="Wrap">
&lt;ic:FluentIcon Icon="Heart" FontSize="16" /&gt;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#CE9178" TextWrapping="Wrap">
&lt;ic:FluentIcon Icon="Heart" FontSize="32" /&gt;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12"
                                       Foreground="#CE9178" TextWrapping="Wrap">
&lt;ic:FluentIcon Icon="Heart" FontSize="48" /&gt;
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,4,0,0">
                        <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                            <ic:FluentIcon Icon="Heart" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="16px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                            <ic:FluentIcon Icon="Heart" FontSize="32" HorizontalAlignment="Center"/>
                            <TextBlock Text="32px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                            <ic:FluentIcon Icon="Heart" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="48px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                            <ic:FluentIcon Icon="Heart" FontSize="64" HorizontalAlignment="Center"/>
                            <TextBlock Text="64px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- C# Usage -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="BracesVariable" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="CSharpTitle" Text="Using in C# Code" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="CSharpDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <StackPanel Spacing="2">
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#C586C0">
using FluentIcons.Avalonia;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#C586C0">
using FluentIcons.Common;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4" Text=""/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#569CD6">
var icon = new FluentIcon
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4">
{
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4">
    Icon = Icon.Home,
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4">
    FontSize = 24,
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4">
    IconVariant = IconVariant.Filled,
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4">
};
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Search Tips -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="Search" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="SearchTipsTitle" Text="Icon Search Tips" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="SearchTipsDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>
                    <StackPanel Spacing="6" Margin="0,4,0,0">
                        <TextBlock x:Name="Tip1" TextWrapping="Wrap" Opacity="0.8" FontSize="14" LineHeight="22"/>
                        <TextBlock x:Name="Tip2" TextWrapping="Wrap" Opacity="0.8" FontSize="14" LineHeight="22"/>
                        <TextBlock x:Name="Tip3" TextWrapping="Wrap" Opacity="0.8" FontSize="14" LineHeight="22"/>
                        <TextBlock x:Name="Tip4" TextWrapping="Wrap" Opacity="0.8" FontSize="14" LineHeight="22"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- More Info -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="BookInformation" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="MoreInfoTitle" Text="More Information" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="MoreInfoDesc" TextWrapping="Wrap" Opacity="0.7" FontSize="14"/>
                    <Button x:Name="RepoButton" Click="RepoButton_Click" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:FluentIcon Icon="Open" IconSize="Size16" FontSize="16"/>
                            <TextBlock x:Name="RepoButtonText" Text="GitHub Repository" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
