<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ic="using:FluentIcons.Avalonia"
             x:Class="FluentIcons.Gallery.SettingsPage">

    <ScrollViewer>
        <StackPanel Margin="40,10,40,32" Spacing="24">

            <!-- Language -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="Globe" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="LangTitle" Text="Language" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="LangDesc" Text="Select interface language" Opacity="0.7" TextWrapping="Wrap"/>
                    <ComboBox x:Name="LanguageCombo" Width="240" HorizontalAlignment="Left"
                              SelectionChanged="LanguageCombo_SelectionChanged">
                        <ComboBoxItem Content="简体中文" Tag="zh-CN"/>
                        <ComboBoxItem Content="English" Tag="en-US"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ic:FluentIcon Icon="Info" IconSize="Size20" FontSize="20"/>
                        <TextBlock x:Name="AboutTitle" Text="About" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="FluentUI Gallery" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Powered by FluentIcons.Avalonia v2.1.329" Opacity="0.5" FontSize="13"/>
                    </StackPanel>

                    <TextBlock x:Name="AboutDesc1" TextWrapping="Wrap" Opacity="0.85" FontSize="14" LineHeight="22"/>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button x:Name="RepoButton" Click="RepoButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ic:FluentIcon Icon="Open" IconSize="Size16" FontSize="16"/>
                                <TextBlock x:Name="RepoButtonText" Text="FluentIcons.Avalonia Repository" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
