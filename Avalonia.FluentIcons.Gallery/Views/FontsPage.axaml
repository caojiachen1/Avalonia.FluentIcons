<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="using:Avalonia.FluentIcons"
             x:Class="Avalonia.FluentIcons.Gallery.FontsPage">

    <ScrollViewer>
        <StackPanel Margin="40,10,40,32" Spacing="28">

            <!-- Regular Font -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <icons:SymbolIcon Symbol="TextFont24" FontSize="22"/>
                        <TextBlock Text="FluentSystemIcons-Regular" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="RegularDesc" Text="FluentSystemIcons-Regular.ttf  |  Outline (stroked) style"
                               FontSize="12" Opacity="0.6"/>

                    <TextBlock Text="ABCDEFGHIJKLM NOPQRSTUVWXYZ" FontSize="32"
                               FontFamily="avares://Avalonia.FluentIcons/Assets/Fonts/FluentSystemIcons-Regular.ttf#FluentSystemIcons-Regular"/>
                    <TextBlock Text="abcdefghijklm nopqrstuvwxyz" FontSize="32"
                               FontFamily="avares://Avalonia.FluentIcons/Assets/Fonts/FluentSystemIcons-Regular.ttf#FluentSystemIcons-Regular"/>
                    <TextBlock Text="0123456789 !@#$%^&amp;*()" FontSize="32"
                               FontFamily="avares://Avalonia.FluentIcons/Assets/Fonts/FluentSystemIcons-Regular.ttf#FluentSystemIcons-Regular"/>

                    <!-- Size samples -->
                    <WrapPanel Margin="0,8,0,0">
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="12"/>
                            <TextBlock Text="12px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="16"/>
                            <TextBlock Text="16px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="20"/>
                            <TextBlock Text="20px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="28"/>
                            <TextBlock Text="28px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="40"/>
                            <TextBlock Text="40px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="56"/>
                            <TextBlock Text="56px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Filled Font -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <icons:SymbolIcon Symbol="TextBold24" FontSize="22" Filled="True"/>
                        <TextBlock Text="FluentSystemIcons-Filled" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="FilledDesc" Text="FluentSystemIcons-Filled.ttf  |  Solid (filled) style"
                               FontSize="12" Opacity="0.6"/>

                    <TextBlock Text="ABCDEFGHIJKLM NOPQRSTUVWXYZ" FontSize="32"
                               FontFamily="avares://Avalonia.FluentIcons/Assets/Fonts/FluentSystemIcons-Filled.ttf#FluentSystemIcons-Filled"/>
                    <TextBlock Text="abcdefghijklm nopqrstuvwxyz" FontSize="32"
                               FontFamily="avares://Avalonia.FluentIcons/Assets/Fonts/FluentSystemIcons-Filled.ttf#FluentSystemIcons-Filled"/>
                    <TextBlock Text="0123456789 !@#$%^&amp;*()" FontSize="32"
                               FontFamily="avares://Avalonia.FluentIcons/Assets/Fonts/FluentSystemIcons-Filled.ttf#FluentSystemIcons-Filled"/>

                    <!-- Size samples -->
                    <WrapPanel Margin="0,8,0,0">
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="12" Filled="True"/>
                            <TextBlock Text="12px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="16" Filled="True"/>
                            <TextBlock Text="16px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="20" Filled="True"/>
                            <TextBlock Text="20px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="28" Filled="True"/>
                            <TextBlock Text="28px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="40" Filled="True"/>
                            <TextBlock Text="40px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="2">
                            <icons:SymbolIcon Symbol="Home24" FontSize="56" Filled="True"/>
                            <TextBlock Text="56px" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Color samples -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="ColorCustomTitle" Text="Color Customization" FontSize="18" FontWeight="SemiBold"/>
                    <WrapPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="4">
                            <icons:SymbolIcon Symbol="Heart24" FontSize="32" Filled="True" Foreground="#E81123"/>
                            <TextBlock Text="#E81123" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="4">
                            <icons:SymbolIcon Symbol="Star24" FontSize="32" Filled="True" Foreground="#FFB900"/>
                            <TextBlock Text="#FFB900" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="4">
                            <icons:SymbolIcon Symbol="LeafTwo24" FontSize="32" Filled="True" Foreground="#107C10"/>
                            <TextBlock Text="#107C10" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="4">
                            <icons:SymbolIcon Symbol="Cloud24" FontSize="32" Filled="True" Foreground="#0078D4"/>
                            <TextBlock Text="#0078D4" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="4">
                            <icons:SymbolIcon Symbol="MusicNote124" FontSize="32" Filled="True" Foreground="#8764B8"/>
                            <TextBlock Text="#8764B8" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,20,8" Spacing="4">
                            <icons:SymbolIcon Symbol="Camera24" FontSize="32" Filled="True" Foreground="#E3008C"/>
                            <TextBlock Text="#E3008C" FontSize="10" Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="" Height="20"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
