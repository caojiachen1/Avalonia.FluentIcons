<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icons="using:Avalonia.FluentIcons"
             x:Class="Avalonia.FluentIcons.Gallery.TutorialPage">

    <ScrollViewer>
        <StackPanel Margin="40,10,40,32" Spacing="24">

            <!-- Step 1: Installation -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource SystemAccentColor}" CornerRadius="12"
                                Width="24" Height="24" HorizontalAlignment="Center">
                            <TextBlock Text="1" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step1Title" Text="Add Project Reference" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="Step1Desc" TextWrapping="Wrap" Opacity="0.8"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4"
                                   TextWrapping="Wrap">
&lt;ItemGroup&gt;
  &lt;ProjectReference Include="..\Avalonia.FluentIcons\Avalonia.FluentIcons.csproj" /&gt;
&lt;/ItemGroup&gt;
                        </TextBlock>
                    </Border>
                    <TextBlock x:Name="Step1Note" TextWrapping="Wrap" Opacity="0.6" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Step 2: XAML Namespace -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource SystemAccentColor}" CornerRadius="12"
                                Width="24" Height="24" HorizontalAlignment="Center">
                            <TextBlock Text="2" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step2Title" Text="Add XAML Namespace" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="Step2Desc" TextWrapping="Wrap" Opacity="0.8"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#CE9178"
                                   TextWrapping="Wrap">
xmlns:icons="using:Avalonia.FluentIcons"
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Step 3: Using SymbolIcon -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource SystemAccentColor}" CornerRadius="12"
                                Width="24" Height="24" HorizontalAlignment="Center">
                            <TextBlock Text="3" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step3Title" Text="Use SymbolIcon" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="BasicUsageLabel" FontWeight="SemiBold" Opacity="0.8"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <StackPanel Spacing="4">
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#608B4E"
                                       Text="&lt;!-- Regular style --&gt;"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#CE9178"
                                       Text="&lt;icons:SymbolIcon Symbol=&quot;Home24&quot; /&gt;"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#608B4E"
                                       TextWrapping="Wrap" Margin="0,8,0,0">
&lt;!-- Filled style --&gt;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#CE9178"
                                       Text="&lt;icons:SymbolIcon Symbol=&quot;Home24&quot; Filled=&quot;True&quot; /&gt;"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                CornerRadius="8" Padding="16,12" HorizontalAlignment="Center">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <icons:SymbolIcon Symbol="Home24" FontSize="28"/>
                                <TextBlock Text="Regular" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                CornerRadius="8" Padding="16,12" HorizontalAlignment="Center">
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <icons:SymbolIcon Symbol="Home24" FontSize="28" Filled="True"/>
                                <TextBlock Text="Filled" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Step 4: Properties -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource SystemAccentColor}" CornerRadius="12"
                                Width="24" Height="24" HorizontalAlignment="Center">
                            <TextBlock Text="4" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step4Title" Text="Customize Properties" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="FontsizeDesc" FontWeight="SemiBold" Opacity="0.8"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#CE9178"
                                   Text="&lt;icons:SymbolIcon Symbol=&quot;Star24&quot; FontSize=&quot;32&quot; /&gt;"/>
                    </Border>
                    <WrapPanel Margin="0,4,0,0">
                        <icons:SymbolIcon Symbol="Star24" FontSize="14" Margin="4"/>
                        <icons:SymbolIcon Symbol="Star24" FontSize="20" Margin="4"/>
                        <icons:SymbolIcon Symbol="Star24" FontSize="28" Margin="4"/>
                        <icons:SymbolIcon Symbol="Star24" FontSize="36" Margin="4"/>
                        <icons:SymbolIcon Symbol="Star24" FontSize="48" Margin="4"/>
                    </WrapPanel>

                    <TextBlock x:Name="ForegroundDesc" FontWeight="SemiBold" Opacity="0.8"
                               Margin="0,12,0,0"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#CE9178"
                                   Text="&lt;icons:SymbolIcon Symbol=&quot;Heart24&quot; Filled=&quot;True&quot; Foreground=&quot;Red&quot; /&gt;"/>
                    </Border>
                    <WrapPanel Margin="0,4,0,0">
                        <icons:SymbolIcon Symbol="Heart24" FontSize="28" Filled="True" Foreground="#E81123" Margin="4"/>
                        <icons:SymbolIcon Symbol="Heart24" FontSize="28" Filled="True" Foreground="#FFB900" Margin="4"/>
                        <icons:SymbolIcon Symbol="Heart24" FontSize="28" Filled="True" Foreground="#107C10" Margin="4"/>
                        <icons:SymbolIcon Symbol="Heart24" FontSize="28" Filled="True" Foreground="#0078D4" Margin="4"/>
                        <icons:SymbolIcon Symbol="Heart24" FontSize="28" Filled="True" Foreground="#8764B8" Margin="4"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Step 5: In Buttons -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource SystemAccentColor}" CornerRadius="12"
                                Width="24" Height="24" HorizontalAlignment="Center">
                            <TextBlock Text="5" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step5Title" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <StackPanel Spacing="4">
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4"
                                       TextWrapping="Wrap">
&lt;Button&gt;
  &lt;StackPanel Orientation=&quot;Horizontal&quot; Spacing=&quot;8&quot;&gt;
    &lt;icons:SymbolIcon Symbol=&quot;Add20&quot; /&gt;
    &lt;TextBlock Text=&quot;Add Item&quot; /&gt;
  &lt;/StackPanel&gt;
&lt;/Button&gt;
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="0,8,0,0" HorizontalAlignment="Left">
                        <Button Margin="0,0,8,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <icons:SymbolIcon Symbol="Add20"/>
                                <TextBlock Text="Add Item"/>
                            </StackPanel>
                        </Button>
                        <Button Margin="0,0,8,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <icons:SymbolIcon Symbol="Delete20"/>
                                <TextBlock Text="Delete"/>
                            </StackPanel>
                        </Button>
                        <Button Margin="0,0,8,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <icons:SymbolIcon Symbol="Settings20"/>
                                <TextBlock Text="Settings"/>
                            </StackPanel>
                        </Button>
                        <Button Margin="0,0,8,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <icons:SymbolIcon Symbol="Save20" Filled="True"/>
                                <TextBlock Text="Save"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Step 6: C# Usage -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource SystemAccentColor}" CornerRadius="12"
                                Width="24" Height="24" HorizontalAlignment="Center">
                            <TextBlock Text="6" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step6Title" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <StackPanel Spacing="4">
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#608B4E"
                                       Text="// Create a SymbolIcon"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap">
var icon = new SymbolIcon(SymbolRegular.Home24);
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#608B4E"
                                       TextWrapping="Wrap" Margin="0,8,0,0">
// Create with Filled style
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap">
var filled = new SymbolIcon(SymbolRegular.Home24,
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap">
    fontSize: 20, filled: true);
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#608B4E"
                                       TextWrapping="Wrap" Margin="0,8,0,0">
// Swap between Regular and Filled
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap">
icon.Symbol = SymbolRegular.Settings24;
                            </TextBlock>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap">
icon.Filled = true;
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Step 7: IconSource pattern -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource SystemAccentColor}" CornerRadius="12"
                                Width="24" Height="24" HorizontalAlignment="Center">
                            <TextBlock Text="7" Foreground="White" FontSize="13" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="Step7Title" FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="Step7Desc" TextWrapping="Wrap" Opacity="0.8"/>
                    <Border Background="#1E1E1E" CornerRadius="4" Padding="12,8">
                        <StackPanel Spacing="4">
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#569CD6"
                                       Text="var source = new SymbolIconSource"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap" Text="{}{"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap" Text="    Symbol = SymbolRegular.Home24,"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap" Text="    Filled = true,"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       TextWrapping="Wrap" Text="    FontSize = 20"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#9CDCFE"
                                       Text="{};"/>
                            <TextBlock FontFamily="Consolas,Menlo,monospace" FontSize="12" Foreground="#D4D4D4"
                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="IconElement icon = source.CreateIconElement();"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Available Controls -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="AvailControlsTitle" Text="Available Controls" FontSize="18" FontWeight="SemiBold"/>

                    <WrapPanel>
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12"
                                MinWidth="200">
                            <StackPanel Spacing="6">
                                <TextBlock Text="SymbolIcon" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock x:Name="CtrlSymbolIconDesc" Opacity="0.7" TextWrapping="Wrap" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12"
                                MinWidth="200">
                            <StackPanel Spacing="6">
                                <TextBlock Text="FontIcon" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock x:Name="CtrlFontIconDesc" Opacity="0.7" TextWrapping="Wrap" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12"
                                MinWidth="200">
                            <StackPanel Spacing="6">
                                <TextBlock Text="ImageIcon" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock x:Name="CtrlImageIconDesc" Opacity="0.7" TextWrapping="Wrap" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,12,12"
                                MinWidth="200">
                            <StackPanel Spacing="6">
                                <TextBlock Text="IconSourceElement" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock x:Name="CtrlIconSourceDesc" Opacity="0.7" TextWrapping="Wrap" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="" Height="20"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
