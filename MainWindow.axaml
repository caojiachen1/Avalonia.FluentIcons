<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ic="using:FluentIcons.Avalonia"
        xmlns:fac="using:FluentAvalonia.UI.Controls"
        x:Class="FluentIcons.Gallery.MainWindow"
        Title="FluentIcons Gallery"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Icon="/Assets/wpfui.ico">

    <fac:FANavigationView x:Name="NavView"
                        IsBackButtonVisible="False"
                        IsSettingsVisible="False"
                        PaneDisplayMode="Left"
                        OpenPaneLength="230"
                        SelectionChanged="NavView_SelectionChanged">
        <fac:FANavigationView.MenuItems>
            <fac:FANavigationViewItem Tag="tutorial">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ic:FluentIcon Icon="BookOpen" IconSize="Size20" FontSize="18"/>
                    <TextBlock x:Name="NavTutorialText" Text="Tutorial" VerticalAlignment="Center"/>
                </StackPanel>
            </fac:FANavigationViewItem>
            <fac:FANavigationViewItem Tag="icons">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ic:FluentIcon Icon="Emoji" IconSize="Size20" FontSize="18"/>
                    <TextBlock x:Name="NavIconsText" Text="Icon Browser" VerticalAlignment="Center"/>
                </StackPanel>
            </fac:FANavigationViewItem>
        </fac:FANavigationView.MenuItems>

        <fac:FANavigationView.FooterMenuItems>
            <fac:FANavigationViewItem Tag="settings">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ic:FluentIcon Icon="Settings" IconSize="Size20" FontSize="18"/>
                    <TextBlock x:Name="NavSettingsText" Text="Settings" VerticalAlignment="Center"/>
                </StackPanel>
            </fac:FANavigationViewItem>
        </fac:FANavigationView.FooterMenuItems>

        <fac:FANavigationView.Header>
            <TextBlock x:Name="HeaderTitleText" Text="Icon Browser" FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="4,8,0,8"/>
        </fac:FANavigationView.Header>

        <ContentControl x:Name="ContentArea"/>
    </fac:FANavigationView>
</Window>
