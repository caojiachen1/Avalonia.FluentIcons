    Fluent System Icons font resource dictionary.
    https://github.com/microsoft/fluentui-system-icons
-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Fluent System Icons - Regular (outline) variant -->
    <FontFamily x:Key="FluentSystemIcons">avares://Avalonia.FluentIcons/Assets/Fonts/FluentSystemIcons-Regular.ttf#FluentSystemIcons-Regular</FontFamily>

    <!-- Fluent System Icons - Filled variant -->
    <FontFamily x:Key="FluentSystemIconsFilled">avares://Avalonia.FluentIcons/Assets/Fonts/FluentSystemIcons-Filled.ttf#FluentSystemIcons-Filled</FontFamily>

    <!-- Default icon font size -->
    <x:Double x:Key="DefaultIconFontSize">14.0</x:Double>

</ResourceDictionary>
